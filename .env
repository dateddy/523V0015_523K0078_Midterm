# Project Configuration

# Project Information
PROJECT_NAME=IMDb Sentiment Analysis Midterm
DESCRIPTION=Binary sentiment classification using MLP and RNN models

# Data Directories
DATA_DIR=./data
CHECKPOINT_DIR=./checkpoints
RESULTS_DIR=./results

# Model Configuration
MAX_VOCAB_SIZE=20000
MAX_SEQUENCE_LENGTH=256
EMBEDDING_DIM=100

# Training Configuration
BATCH_SIZE=64
LEARNING_RATE=0.001
WEIGHT_DECAY=0.00001
MAX_EPOCHS=20
PATIENCE=3
MAX_GRAD_NORM=1.0

# Data Split
TRAIN_SIZE=0.70
VAL_SIZE=0.10
TEST_SIZE=0.20

# Random Seed (Reproducibility)
SEED=42

# Device Configuration
DEVICE=cuda
# Use DEVICE=cpu if CUDA is not available

# Verbosity
VERBOSE=True
